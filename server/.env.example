# Required for real AI codegen (without this, the studio returns a stub vault).
# Accepts an OpenAI key (sk-…) or an Anthropic key (sk-ant-…) — see OPENAI_BASE_URL.
OPENAI_API_KEY=sk-...

# Chat history persistence (optional — in-memory fallback when unset).
# Apply supabase/schema.sql manually before setting these.
# SERVER-ONLY: never expose the service role key to frontend code.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...

# Optional: OpenAI-compatible gateway. Leave unset for api.openai.com.
# For Anthropic/Claude: https://api.anthropic.com/v1/ (with an sk-ant-… key and
# a claude-* model below). Unsupported params are adapted automatically.
# OPENAI_BASE_URL=https://api.anthropic.com/v1/

# Model used for codegen + spec audit + economic critic + auto-repair.
# gpt-5.4 — coding/professional work (default). gpt-5.5 — stronger reasoning, higher cost.
# With OPENAI_BASE_URL pointed at Anthropic: claude-sonnet-5 (coding flagship).
# Cost-safe deployments can set a mini/cheaper model here.
OPENAI_MODEL=gpt-5.4

# Optional: stronger model for ONE final repair escalation attempt when normal
# repair attempts fail. Leave unset to disable escalation entirely.
# OPENAI_ESCALATION_MODEL=gpt-5.5

# Optional: cheap model for advisory calls (scope classifier, spec pre-audit,
# economic critic — none of them gate the pipeline). Falls back to OPENAI_MODEL.
# Strongly recommended for cost: with Anthropic use claude-haiku-4-5 (~1/3 the
# input price and 1/3 the output price of a sonnet-class model).
# OPENAI_CHEAP_MODEL=claude-haiku-4-5

# Secret for signing wallet session tokens (any long random string, e.g.
# `openssl rand -hex 32`). Unset = random per-process secret: fine for dev,
# but sessions reset on every server restart.
# AUTH_SECRET=

# AI server port (Railway sets PORT automatically).
PORT=3002

# Comma-separated Vercel origin(s) for CORS, e.g. https://your-app.vercel.app
# CORS_ORIGIN=https://your-app.vercel.app
