# Required for real AI codegen (without this, the studio returns a stub vault).
OPENAI_API_KEY=sk-...

# Model used for codegen + spec audit.
# gpt-4.1 is stronger on Solidity logic; gpt-4o is faster/cheaper. Logic bugs are also caught by scanSafety.
OPENAI_MODEL=gpt-4.1

# AI server port (Railway sets PORT automatically).
PORT=3002

# Comma-separated Vercel origin(s) for CORS, e.g. https://your-app.vercel.app
# CORS_ORIGIN=https://your-app.vercel.app
