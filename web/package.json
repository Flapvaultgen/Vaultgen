{
  "name": "vault-composer-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:vault-runtime && vite",
    "dev:server": "npm --prefix ../server run dev",
    "dev:all": "npm run build:vault-runtime && concurrently -n web,ai -c blue,magenta \"vite\" \"npm --prefix ../server run dev\"",
    "build": "npm run build:vault-runtime && node scripts/export-flap-artifacts.mjs && node scripts/write-config.mjs && tsc && vite build",
    "build:vault-runtime": "tsx scripts/build-vault-runtime.mts",
    "preview": "vite preview",
    "test:register": "tsx scripts/register-validation-selfcheck.mts",
    "test:launch": "tsx scripts/launch-validation-selfcheck.mts",
    "test:vault-state": "tsx scripts/vault-state-selfcheck.mts",
    "test:vault-ui": "tsx scripts/vault-ui-schema-selfcheck.mts",
    "test:vault-ui-bridge": "tsx scripts/vault-ui-bridge-selfcheck.mts",
    "test": "npm run test:register && npm run test:launch && npm run test:vault-state && npm run test:vault-ui && npm run test:vault-ui-bridge"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.21.54",
    "wagmi": "^3.6.16"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.1",
    "jszip": "^3.10.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
