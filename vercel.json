{
  "$schema": "https://openapi.vercel.com/vercel.json",
  "installCommand": "npm ci --prefix web",
  "buildCommand": "npm run build --prefix web",
  "outputDirectory": "web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://flapvaultgen-production.up.railway.app/api/:path*"
    }
  ]
}
